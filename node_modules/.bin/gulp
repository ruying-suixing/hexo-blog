#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/mnt/c/Users/22790/hexo-blog/node_modules/.pnpm/gulp@5.0.1/node_modules/gulp/node_modules:/mnt/c/Users/22790/hexo-blog/node_modules/.pnpm/gulp@5.0.1/node_modules:/mnt/c/Users/22790/hexo-blog/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/mnt/c/Users/22790/hexo-blog/node_modules/.pnpm/gulp@5.0.1/node_modules/gulp/node_modules:/mnt/c/Users/22790/hexo-blog/node_modules/.pnpm/gulp@5.0.1/node_modules:/mnt/c/Users/22790/hexo-blog/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../gulp/bin/gulp.js" "$@"
else
  exec node  "$basedir/../gulp/bin/gulp.js" "$@"
fi
